{
	"name": "oai-proxy",
	"version": "1.0.0",
	"description": "OpenAI API proxy with token tracking and daily limits",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "bun run index.ts",
		"dev": "bun --watch index.ts",
		"dev:dashboard": "cd dashboard && bun run dev",
		"build:dashboard": "cd dashboard && bun run build",
		"docker:build": "docker build -t oai-proxy .",
		"docker:run": "docker run -p 3000:3000 --env-file .env -v $(pwd)/db:/app/db oai-proxy"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/bun": "^1.3.11",
		"@vitejs/plugin-react": "^6.0.1"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"hono": "^4.12.9",
		"openai": "^6.33.0"
	}
}
